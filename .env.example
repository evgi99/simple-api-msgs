# Server
PORT=3000

# MongoDB (use mongodb://localhost:27017/herolo-messaging for local)
MONGODB_URI=mongodb://localhost:27017/herolo-messaging

# JWT — required in production: set a long random secret (e.g. openssl rand -base64 32)
JWT_SECRET=change-me-in-production
# Access token lifetime (default 15m). Refresh token is fixed at 7d.
# JWT_ACCESS_EXPIRES_IN=15m

# CORS — required in production: comma-separated allowed origins (e.g. https://app.example.com)
# Leave unset for development (allows all origins)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
